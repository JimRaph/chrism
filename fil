-- 1. PRODUCTS TABLE
-- Stores fuel products shown in the price ticker and calculator
CREATE TABLE IF NOT EXISTS products (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  name TEXT NOT NULL,
  code TEXT NOT NULL UNIQUE,
  price NUMERIC NOT NULL DEFAULT 0,
  unit TEXT NOT NULL DEFAULT 'litre',
  is_available BOOLEAN NOT NULL DEFAULT true,
  updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

-- Auto-update the updated_at timestamp
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = now();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER update_products_updated_at
  BEFORE UPDATE ON products
  FOR EACH ROW
  EXECUTE FUNCTION update_updated_at_column();

-- 2. LPG SIZES TABLE
-- Stores pre-defined LPG cylinder sizes and their prices
CREATE TABLE IF NOT EXISTS lpg_sizes (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  size_kg NUMERIC NOT NULL,
  price NUMERIC NOT NULL DEFAULT 0,
  is_available BOOLEAN NOT NULL DEFAULT true,
  updated_at TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE TRIGGER update_lpg_sizes_updated_at
  BEFORE UPDATE ON lpg_sizes
  FOR EACH ROW
  EXECUTE FUNCTION update_updated_at_column();

